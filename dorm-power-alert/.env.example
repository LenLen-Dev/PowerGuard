# App
APP_NAME=DormPowerAlert
CHECK_INTERVAL_SECONDS=300
LOW_BALANCE_THRESHOLD=10
ALERT_COOLDOWN_SECONDS=1800
REQUEST_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO
# Optional: headless multi-dorm JSON profile file
# If exists and has entries, run.py will use multi-dorm mode.
DORM_PROFILES_FILE=gui_profiles.json
# Optional: headless log file path (weekly auto-clear)
HEADLESS_LOG_FILE=logs/headless_monitor.log
# Optional: GUI log file path (weekly auto-clear)
GUI_LOG_FILE=logs/gui_monitor.log

# API
BASE_URL=http://tysf.ahpu.edu.cn:8063/web/Common/Tsm.html
REFERER=http://tysf.ahpu.edu.cn:8063/web/whatever/your_page
JSESSIONID=your_jsessionid_here
AID=0030000000002501
ACCOUNT=54963
AREA=安徽工程大学
AREA_NAME=安徽工程大学
BUILDING_ID=10
BUILDING_NAME="男19#楼"
ROOM_ID=215
ROOM_NAME=215

# Email (SMTP)
# Single sender (kept for backward compatibility)
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@example.com
EMAIL_TO=receiver@example.com

# Sender pool (optional, JSON array string)
# EMAIL_POOL=[{"smtp_host":"smtp.qq.com","smtp_port":587,"use_tls":true,"username":"a@qq.com","password":"codeA","sender":"a@qq.com"},{"smtp_host":"smtp.163.com","smtp_port":465,"use_tls":true,"username":"b@163.com","password":"codeB","sender":"b@163.com"}]
# Sender pool file (recommended for long configs, JSON array)
# EMAIL_POOL_FILE=email_pool.json

# Queue sending
EMAIL_QUEUE_MAX_SIZE=200
EMAIL_QUEUE_PUT_TIMEOUT_SECONDS=2
EMAIL_QUEUE_MAX_ATTEMPTS=3
EMAIL_QUEUE_RETRY_BACKOFF_SECONDS=1.5
